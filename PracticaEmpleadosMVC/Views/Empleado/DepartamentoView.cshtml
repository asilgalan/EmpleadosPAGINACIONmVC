@model IEnumerable<PracticaEmpleadosMVC.Models.Departamento>

@{
    ViewData["Title"] = "DepartamentosView";
}

<h1>DepartamentosView</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Id)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Nombre)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Localidad)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.Id)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Nombre)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Localidad)
                </td>
                <td>
                    <a asp-controller="Empleado" asp-action="EmpleadosDepartamentoOut" asp-route-idDepartamento="@item.Id" asp-route-posicion="1">Ver empleados</a>
                </td>
            </tr>
        }
    </tbody>
</table>